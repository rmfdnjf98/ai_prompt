<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join Form</title>
</head>
<body>
<h1>Join Form</h1>
<hr/>
<form action="/join" method="post">
    <input type="text" name="username" id="username" placeholder="Enter username">
    <button type="button" onclick="checkUsername()">Check Username</button>
    <div id="username-check-msg"></div>
    <br>
    <input type="password" name="password" placeholder="Enter password"><br>
    <input type="email" name="email" placeholder="Enter email"><br>
    <button>Join</button>
</form>

<script>
    async function checkUsername() {
        // 1. 입력값 가져오기
        let username = document.querySelector("#username").value;
        let msgEl = document.querySelector("#username-check-msg");

        // 2. 기본 검증
        if (!username || username.trim() === "") {
            msgEl.innerHTML = "아이디를 입력해주세요.";
            return;
        }

        // 3. fetch API 호출
        try {
            let response = await fetch(`/api/users/username-check?username=${username}`);
            let result = await response.json(); // Resp<Boolean>

            // 4. 응답 결과에 따라 DOM 업데이트
            if (response.status === 200) {
                if (result.body === true) { // body는 isTaken 값
                    msgEl.innerHTML = "이미 사용중인 아이디입니다.";
                    msgEl.style.color = "red";
                } else {
                    msgEl.innerHTML = "사용 가능한 아이디입니다.";
                    msgEl.style.color = "green";
                }
            } else {
                // HTTP 상태 코드가 200이 아닌 경우
                alert(result.msg || "확인에 실패했습니다.");
            }
        } catch (error) {
            console.error(error);
            alert("통신 오류가 발생했습니다.");
        }
    }
</script>

</body>
</html>
