<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>주소 검색</title>
</head>
<body onload="init();">
    <form id="form" name="form" method="post">
        <!-- 해당 요청에 대한 반환 주소 (자기 자신을 다시 호출하여 POST 데이터를 받음) -->
        <input type="hidden" name="returnUrl" id="returnUrl" value=""/>
        <!-- 도로명주소 팝업 API 승인키 (실제 운영 시에는 개별 발급 필요) -->
        <input type="hidden" name="confmKey" id="confmKey" value="devU01TX000000000000001"/>
        <input type="hidden" name="resultType" id="resultType" value="4"/> <!-- 4: JSON, 생략 시 XML -->
    </form>

    <script>
        function init() {
            let url = location.href;
            let confmKey = "devU01TX000000000000001"; // 테스트용 승인키
            let resultType = "4"; // JSON 타입
            let inputYn = "N"; // 검색 전

            // 자기 자신의 URL을 returnUrl로 설정하여 결과를 POST로 받도록 함
            document.form.returnUrl.value = url;
            
            // 행안부 팝업 서비스 호출 (GET 또는 POST)
            // 실제 API 서버 주소: https://www.juso.go.kr/addrlink/addrLinkUrl.do
            document.form.action = "https://www.juso.go.kr/addrlink/addrLinkUrl.do";
            document.form.submit();
        }
    </script>
</body>
</html>
